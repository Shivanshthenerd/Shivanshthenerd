  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Feature Engineering & Preprocessing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Additional derived features ───────────────────────────────────────────────\n",
    "df_monthly['expense_alpha_ratio'] = df_monthly['expense_ratio'] / (df_monthly['alpha'].abs() + 0.01)\n",
    "df_monthly['return_volatility_ratio'] = df_monthly['roll_3m_return'] / (df_monthly['vol_3m'] + 1e-6)\n",
    "df_monthly['drawdown_duration']  = (df_monthly['drawdown'] < -0.05).astype(int)\n",
    "df_monthly['momentum']           = df_monthly['roll_3m_return'] - df_monthly['roll_6m_return']\n",
    "df_monthly['rating_expense']     = df_monthly['rating'] / (df_monthly['expense_ratio'] + 0.01)\n",
    "\n",
    "print('Derived features added')\n",
    "print(df_monthly[['expense_alpha_ratio','return_volatility_ratio','momentum','rating_expense']].describe().T)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build feature matrix ──────────────────────────────────────────────────────\n",
    "drop_cols = ['fund_id', 'month', 'churn', 'churn_prob', 'category_label']\n",
    "feature_cols = [c for c in df_monthly.columns if c not in drop_cols]\n",
    "\n",
    "X = df_monthly[feature_cols].values.astype(np.float32)\n",
    "y = df_monthly['churn'].values.astype(np.int32)\n",
    "\n",
    "print(f'Feature matrix : {X.shape}')\n",
    "print(f'Target         : {y.shape}  (churn rate {y.mean():.2%})')\n",
    "print(f'Features used  : {feature_cols}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train / Validation / Test split ──────────────────────────────────────────\n",
    "# Use temporal split: train on first 80 months, validate on next 20, test on last 20\n",
    "idx = np.arange(len(df_monthly))\n",
    "\n",
    "idx_tr, idx_tmp = train_test_split(idx, test_size=0.25, random_state=SEED, stratify=y)\n",
    "idx_val, idx_test = train_test_split(idx_tmp, test_size=0.50, random_state=SEED,\n",
    "                                     stratify=y[idx_tmp])\n",
    "\n",
    "X_train, X_val, X_test = X[idx_tr], X[idx_val], X[idx_test]\n",
    "y_train, y_val, y_test = y[idx_tr], y[idx_val], y[idx_test]\n",
    "\n",
    "print(f'Train : {X_train.shape}  |  Val : {X_val.shape}  |  Test : {X_test.shape}')\n",
    "print(f'Train churn rate: {y_train.mean():.2%}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "scaler = StandardScaler()\n",
    "X_train_sc = scaler.fit_transform(X_train)\n",
    "X_val_sc   = scaler.transform(X_val)\n",
    "X_test_sc  = scaler.transform(X_test)\n",
    "print('Scaling done.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. Class-Imbalance Handling (SMOTE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "smote = SMOTE(random_state=SEED)\n",
    "X_train_res, y_train_res = smote.fit_resample(X_train_sc, y_train)\n",
    "\n",
    "print(f'Before SMOTE → Active: {(y_train==0).sum():,}  Churned: {(y_train==1).sum():,}')\n",
    "print(f'After  SMOTE → Active: {(y_train_res==0).sum():,}  Churned: {(y_train_res==1).sum():,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Baseline — Logistic Regression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lr = LogisticRegression(max_iter=1000, random_state=SEED, C=0.1)\n",
    "lr.fit(X_train_res, y_train_res)\n",
    "\n",
    "lr_pred  = lr.predict(X_test_sc)\n",
    "lr_proba = lr.predict_proba(X_test_sc)[:, 1]\n",
    "\n",
    "print('=== Logistic Regression — Test Set ===')\n",
    "print(classification_report(y_test, lr_pred, target_names=['Active', 'Churned']))\n",
    "print(f'ROC-AUC : {roc_auc_score(y_test, lr_proba):.4f}')\n",
    "print(f'Avg Prec: {average_precision_score(y_test, lr_proba):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 6. Deep Neural Network (DNN)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_dnn(input_dim: int) -> keras.Model:\n",
    "    inp = keras.Input(shape=(input_dim,), name='fund_features')\n",
    "\n",
    "    x = layers.Dense(256, kernel_regularizer=regularizers.l2(1e-4))(inp)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.Activation('relu')(x)\n",
    "    x = layers.Dropout(0.35)(x)\n",
    "\n",
    "    x = layers.Dense(128, kernel_regularizer=regularizers.l2(1e-4))(x)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.Activation('relu')(x)\n",
    "    x = layers.Dropout(0.30)(x)\n",
    "\n",
    "    x = layers.Dense(64, kernel_regularizer=regularizers.l2(1e-4))(x)\n",
    "    x = layers.BatchNormalization()(x)\n",
    "    x = layers.Activation('relu')(x)\n",
    "    x = layers.Dropout(0.20)(x)\n",
    "\n",
    "    x = layers.Dense(32, activation='relu')(x)\n",
    "\n",
    "    out = layers.Dense(1, activation='sigmoid', name='churn_prob')(x)\n",
    "\n",
    "    model = keras.Model(inp, out)\n",
    "    model.compile(\n",
    "        optimizer=keras.optimizers.Adam(learning_rate=1e-3),\n",
    "        loss='binary_crossentropy',\n",
    "        metrics=['accuracy', keras.metrics.AUC(name='auc')]\n",
    "    )\n",
    "    return model\n",
    "\n",
    "\n",
    "os.makedirs('models', exist_ok=True)\n",
    "\n",
    "dnn = build_dnn(X_train_res.shape[1])\n",
    "dnn.summary()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dnn_cbs = [\n",
    "    callbacks.EarlyStopping(monitor='val_auc', patience=10, restore_best_weights=True, mode='max'),\n",
    "    callbacks.ReduceLROnPlateau(monitor='val_auc', factor=0.5, patience=4, mode='max', min_lr=1e-6),\n",
    "    callbacks.ModelCheckpoint('models/dnn_best.keras', monitor='val_auc',\n",
    "                               save_best_only=True, mode='max', verbose=0)\n",
    "]\n",
    "\n",
    "history = dnn.fit(\n",
    "    X_train_res, y_train_res,\n",
    "    validation_data=(X_val_sc, y_val),\n",
    "    epochs=80,\n",
    "    batch_size=1024,\n",
    "    callbacks=dnn_cbs,\n",
    "    verbose=1\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Training curves ───────────────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 4))\n",
    "\n",
    "for ax, metric, title in zip(axes,\n",
    "                              ['loss', 'accuracy', 'auc'],\n",
    "                              ['Loss', 'Accuracy', 'ROC-AUC']):\n",
    "    ax.plot(history.history[metric],          label='Train')\n",
    "    ax.plot(history.history[f'val_{metric}'], label='Validation')\n",
    "    ax.set_title(title); ax.set_xlabel('Epoch'); ax.legend()\n",
    "\n",
    "plt.suptitle('DNN Training History', fontsize=13, fontweight='bold')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dnn_proba = dnn.predict(X_test_sc, verbose=0).flatten()\n",
    "dnn_pred  = (dnn_proba >= 0.50).astype(int)\n",
    "\n",
    "print('=== DNN — Test Set ===')\n",
    "print(classification_report(y_test, dnn_pred, target_names=['Active', 'Churned']))\n",
    "print(f'ROC-AUC : {roc_auc_score(y_test, dnn_proba):.4f}')\n",
    "print(f'Avg Prec: {average_precision_score(y_test, dnn_proba):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 7. LSTM on Sequential Monthly Performance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build 12-month look-back sequences per fund\n",
    "SEQ_LEN     = 12\n",
    "SEQ_FEATURES = ['monthly_return', 'roll_3m_return', 'vol_3m',\n",
    "                'drawdown', 'rel_perf_vs_cat', 'nav_ratio_12m']\n",
    "\n",
    "def build_sequences(dataframe: pd.DataFrame,\n",
    "                    seq_len: int = SEQ_LEN) -> tuple:\n",
    "    seqs, labels = [], []\n",
    "    for fid, grp in dataframe.groupby('fund_id'):\n",
    "        grp = grp.sort_values('month')\n",
    "        vals = grp[SEQ_FEATURES].values.astype(np.float32)\n",
    "        y_   = grp['churn'].values\n",
    "        for t in range(seq_len, len(grp)):\n",
    "            seqs.append(vals[t - seq_len : t])\n",
    "            labels.append(y_[t])\n",
    "    return np.array(seqs, dtype=np.float32), np.array(labels, dtype=np.int32)\n",
    "\n",
    "print('Building sequences … (this may take ~30 s)')\n",
    "S_all, y_seq_all = build_sequences(df_monthly)\n",
    "print(f'Sequences shape: {S_all.shape}  |  Labels: {y_seq_all.shape}')\n",
    "print(f'Churn rate in sequences: {y_seq_all.mean():.2%}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Normalise sequence features ───────────────────────────────────────────────\n",
    "S_flat = S_all.reshape(len(S_all), -1)\n",
    "seq_scaler = StandardScaler()\n",
    "\n",
    "idx_str, idx_stmp = train_test_split(np.arange(len(S_all)), test_size=0.25,\n",
    "                                     random_state=SEED, stratify=y_seq_all)\n",
    "idx_sval, idx_stest = train_test_split(idx_stmp, test_size=0.50,\n",
    "                                       random_state=SEED, stratify=y_seq_all[idx_stmp])\n",
    "\n",
    "S_flat_tr = seq_scaler.fit_transform(S_flat[idx_str])\n",
    "S_flat_val  = seq_scaler.transform(S_flat[idx_sval])\n",
    "S_flat_test = seq_scaler.transform(S_flat[idx_stest])\n",
    "\n",
    "S_train_3d = S_flat_tr.reshape(-1, SEQ_LEN, len(SEQ_FEATURES))\n",
    "S_val_3d   = S_flat_val.reshape(-1, SEQ_LEN, len(SEQ_FEATURES))\n",
    "S_test_3d  = S_flat_test.reshape(-1, SEQ_LEN, len(SEQ_FEATURES))\n",
    "\n",
    "y_str  = y_seq_all[idx_str]\n",
    "y_sval = y_seq_all[idx_sval]\n",
    "y_stest= y_seq_all[idx_stest]\n",
    "\n",
    "print(f'Train:{S_train_3d.shape} Val:{S_val_3d.shape} Test:{S_test_3d.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── SMOTE on LSTM training set ────────────────────────────────────────────────\n",
    "S_flat_res, y_str_res = smote.fit_resample(\n",
    "    S_train_3d.reshape(len(S_train_3d), -1), y_str)\n",
    "S_train_res = S_flat_res.reshape(-1, SEQ_LEN, len(SEQ_FEATURES))\n",
    "print(f'After SMOTE — sequences: {S_train_res.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_lstm(seq_len: int = SEQ_LEN, n_feat: int = len(SEQ_FEATURES)) -> keras.Model:\n",
    "    inp = keras.Input(shape=(seq_len, n_feat), name='monthly_seq')\n",
    "\n",
    "    x = layers.LSTM(64, return_sequences=True, dropout=0.2, recurrent_dropout=0.1)(inp)\n",
    "    x = layers.LSTM(32, dropout=0.2)(x)\n",
    "    x = layers.Dense(32, activation='relu')(x)\n",
    "    x = layers.Dropout(0.2)(x)\n",
    "    out = layers.Dense(1, activation='sigmoid', name='churn_prob')(x)\n",
    "\n",
    "    model = keras.Model(inp, out)\n",
    "    model.compile(\n",
    "        optimizer=keras.optimizers.Adam(1e-3),\n",
    "        loss='binary_crossentropy',\n",
    "        metrics=['accuracy', keras.metrics.AUC(name='auc')]\n",
    "    )\n",
    "    return model\n",
    "\n",
    "lstm_model = build_lstm()\n",
    "lstm_model.summary()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lstm_cbs = [\n",
    "    callbacks.EarlyStopping(monitor='val_auc', patience=10, restore_best_weights=True, mode='max'),\n",
    "    callbacks.ReduceLROnPlateau(monitor='val_auc', factor=0.5, patience=4, mode='max', min_lr=1e-6),\n",
    "    callbacks.ModelCheckpoint('models/lstm_best.keras', monitor='val_auc',\n",
    "                               save_best_only=True, mode='max', verbose=0)\n",
    "]\n",
    "\n",
    "lstm_history = lstm_model.fit(\n",
    "    S_train_res, y_str_res,\n",
    "    validation_data=(S_val_3d, y_sval),\n",
    "    epochs=60,\n",
    "    batch_size=1024,\n",
    "    callbacks=lstm_cbs,\n",
    "    verbose=1\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "lstm_proba = lstm_model.predict(S_test_3d, verbose=0).flatten()\n",
    "lstm_pred  = (lstm_proba >= 0.50).astype(int)\n",
    "\n",
    "print('=== LSTM — Test Set ===')\n",
    "print(classification_report(y_stest, lstm_pred, target_names=['Active', 'Churned']))\n",
    "print(f'ROC-AUC : {roc_auc_score(y_stest, lstm_proba):.4f}')\n",
    "print(f'Avg Prec: {average_precision_score(y_stest, lstm_proba):.4f}')"
   ]
  },
